<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Se o arquivo ou diretório solicitado existir fisicamente, acesse diretamente
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
  
  # Caso contrário, redirecione todas as outras requisições para o index.html (Roteamento do React/Wouter)
  RewriteRule ^ index.html [L]
</IfModule>
